# Find MLX C
#
# Defines the following variables:
#
#   MLX_C_FOUND            : True if MLX C is found
#   MLX_C_INCLUDE_DIRS     : Include directory
#   MLX_C_LIBRARIES        : Libraries to link against
#   MLX_C_CXX_FLAGS        : Additional compiler flags

@PACKAGE_INIT@

set_and_check(MLX_C_LIBRARY_DIRS @PACKAGE_CMAKE_INSTALL_LIBDIR@)
set_and_check(MLX_C_INCLUDE_DIRS @PACKAGE_CMAKE_INSTALL_INCLUDEDIR@)

find_library(MLX_C_LIBRARY mlxc PATHS ${MLX_C_LIBRARY_DIRS})
find_library(MLX_C_BACKING_LIBRARY mlx PATHS ${MLX_C_LIBRARY_DIRS})
if(MLX_C_BACKING_LIBRARY AND NOT TARGET mlx)
  add_library(mlx UNKNOWN IMPORTED)
  set_target_properties(mlx PROPERTIES IMPORTED_LOCATION
                                       "${MLX_C_BACKING_LIBRARY}")
endif()

set(MLX_C_HAS_JACCL @MLX_C_HAS_JACCL@)
if(MLX_C_HAS_JACCL)
  set(MLX_C_JACCL_TARGETS
      @PACKAGE_CMAKE_INSTALL_LIBDIR@/cmake/jaccl/jacclTargets.cmake)
  if(EXISTS "${MLX_C_JACCL_TARGETS}")
    include("${MLX_C_JACCL_TARGETS}")
  endif()
  find_library(MLX_C_JACCL_LIBRARY jacclc PATHS ${MLX_C_LIBRARY_DIRS})
  find_library(MLX_C_JACCL_BACKING_LIBRARY jaccl PATHS ${MLX_C_LIBRARY_DIRS})
  if(MLX_C_JACCL_BACKING_LIBRARY AND NOT TARGET jaccl::jaccl)
    add_library(jaccl::jaccl UNKNOWN IMPORTED)
    set_target_properties(jaccl::jaccl PROPERTIES
                          IMPORTED_LOCATION "${MLX_C_JACCL_BACKING_LIBRARY}")
  endif()
endif()

if(NOT CMAKE_CXX_COMPILER_LOADED)
  enable_language(CXX)
endif()

include(@PACKAGE_MLX_C_CMAKE_INSTALL_MODULE_DIR@/MLXCTargets.cmake)

set(MLX_C_LIBRARIES mlxc)
if(MLX_C_HAS_JACCL)
  list(APPEND MLX_C_LIBRARIES jacclc)
endif()

# set_target_properties(mlxc PROPERTIES
#    CXX_STANDARD 17
#    INTERFACE_COMPILE_OPTIONS "${MLX_C_CXX_FLAGS}"
# )

include(FindPackageHandleStandardArgs)
if(MLX_C_HAS_JACCL)
  find_package_handle_standard_args(
    MLXC
    DEFAULT_MSG
    MLX_C_LIBRARY
    MLX_C_BACKING_LIBRARY
    MLX_C_JACCL_LIBRARY
    MLX_C_JACCL_BACKING_LIBRARY
    MLX_C_INCLUDE_DIRS)
else()
  find_package_handle_standard_args(
    MLXC DEFAULT_MSG MLX_C_LIBRARY MLX_C_BACKING_LIBRARY MLX_C_INCLUDE_DIRS)
endif()

set(MLX_C_FOUND ${MLXC_FOUND})
