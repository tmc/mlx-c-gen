#!/usr/bin/env bash
set -euo pipefail

repo=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
cd "$repo"

if [ -n "${MLX_C_CHECK_CACHE:-}" ]; then
  cache_dir=$MLX_C_CHECK_CACHE
elif [ "$(uname -s)" = Darwin ]; then
  cache_dir="${HOME}/Library/Caches/mlx-c/check"
else
  cache_dir="${XDG_CACHE_HOME:-${HOME}/.cache}/mlx-c/check"
fi

if command -v shasum >/dev/null 2>&1; then
  repo_key=$(printf '%s' "$repo" | shasum -a 256 | awk '{print substr($1, 1, 16)}')
else
  repo_key=$(printf '%s' "$repo" | sha256sum | awk '{print substr($1, 1, 16)}')
fi
root="$cache_dir/$repo_key"
cmake_generator="${MLX_C_CHECK_CMAKE_GENERATOR:-}"
if [ -z "$cmake_generator" ] && command -v ninja >/dev/null 2>&1; then
  cmake_generator=Ninja
fi

if [ -n "${MLX_C_CHECK_BUILD_DIR:-}" ]; then
  build_dir=$MLX_C_CHECK_BUILD_DIR
elif [ "$cmake_generator" = Ninja ]; then
  build_dir="$root/build-shared-ninja"
else
  build_dir="$root/build-shared"
fi
if [ -n "${MLX_C_CHECK_NO_JACCL_BUILD_DIR:-}" ]; then
  no_jaccl_build_dir=$MLX_C_CHECK_NO_JACCL_BUILD_DIR
elif [ "$cmake_generator" = Ninja ]; then
  no_jaccl_build_dir="$root/build-no-jaccl-ninja"
else
  no_jaccl_build_dir="$root/build-no-jaccl"
fi
if [ -n "${MLX_C_CHECK_WORK_DIR:-}" ]; then
  work_dir=$MLX_C_CHECK_WORK_DIR
elif [ "$cmake_generator" = Ninja ]; then
  work_dir="$root/install-smoke-ninja"
else
  work_dir="$root/install-smoke"
fi
if [ -n "${MLX_C_CHECK_NO_JACCL_WORK_DIR:-}" ]; then
  no_jaccl_work_dir=$MLX_C_CHECK_NO_JACCL_WORK_DIR
elif [ "$cmake_generator" = Ninja ]; then
  no_jaccl_work_dir="$root/install-smoke-no-jaccl-ninja"
else
  no_jaccl_work_dir="$root/install-smoke-no-jaccl"
fi
if [ -n "${MLX_C_CHECK_JACCL_REQUIRED_WORK_DIR:-}" ]; then
  jaccl_required_work_dir=$MLX_C_CHECK_JACCL_REQUIRED_WORK_DIR
elif [ "$cmake_generator" = Ninja ]; then
  jaccl_required_work_dir="$root/install-smoke-jaccl-required-ninja"
else
  jaccl_required_work_dir="$root/install-smoke-jaccl-required"
fi
if [ -n "${MLX_C_CHECK_NO_JACCL_REQUIRED_WORK_DIR:-}" ]; then
  no_jaccl_required_work_dir=$MLX_C_CHECK_NO_JACCL_REQUIRED_WORK_DIR
elif [ "$cmake_generator" = Ninja ]; then
  no_jaccl_required_work_dir="$root/install-smoke-no-jaccl-required-ninja"
else
  no_jaccl_required_work_dir="$root/install-smoke-no-jaccl-required"
fi
report="${MLX_C_CHECK_REPORT:-$root/report.json}"
parse_dir="${MLX_C_CHECK_PARSE_DIR:-$root/parse}"
ast_cache="${MLX_C_CHECK_AST_CACHE:-$root/ast}"
lock_obj="${MLX_C_CHECK_LOCK_OBJ:-$root/lock.o}"
mlx_src="${MLX_C_SRC:-}"
cc_cmd="${MLX_C_CHECK_CC:-cc}"
if [ "${MLX_C_CHECK_COMPILER_LAUNCHER+x}" = x ]; then
  compiler_launcher_setting=$MLX_C_CHECK_COMPILER_LAUNCHER
else
  compiler_launcher_setting=auto
fi

resolve_compiler_launcher() {
  case "$compiler_launcher_setting" in
  "")
    return 0
    ;;
  auto)
    command -v sccache 2>/dev/null || command -v ccache 2>/dev/null || true
    ;;
  *)
    if command -v "$compiler_launcher_setting" >/dev/null 2>&1; then
      command -v "$compiler_launcher_setting"
    elif [ -x "$compiler_launcher_setting" ]; then
      printf '%s\n' "$compiler_launcher_setting"
    else
      printf 'compiler launcher not found: %s\n' "$compiler_launcher_setting" >&2
      exit 1
    fi
    ;;
  esac
}
compiler_launcher=$(resolve_compiler_launcher)

mkdir -p "$root" "$parse_dir" "$ast_cache"

cmake_args=(
  -S .
  -B "$build_dir"
  -DCMAKE_BUILD_TYPE=RelWithDebInfo
  -DBUILD_SHARED_LIBS=ON
  -DMLX_C_BUILD_EXAMPLES=ON
  "-DMLX_C_COMPILER_LAUNCHER=$compiler_launcher_setting"
)
if [ -n "$cmake_generator" ]; then
  cmake_args=(-G "$cmake_generator" "${cmake_args[@]}")
fi

if [ -z "$mlx_src" ] && [ -d /Users/tmc/ml-explore/mlx ]; then
  mlx_src=/Users/tmc/ml-explore/mlx
fi
if [ -n "$mlx_src" ]; then
  cmake_args+=("-DFETCHCONTENT_SOURCE_DIR_MLX=$mlx_src")
else
  mlx_src="$build_dir/_deps/mlx-src"
fi
no_jaccl_cmake_args=(
  -S .
  -B "$no_jaccl_build_dir"
  -DCMAKE_BUILD_TYPE=RelWithDebInfo
  -DBUILD_SHARED_LIBS=ON
  -DMLX_C_BUILD_EXAMPLES=ON
  -DMLX_C_BUILD_JACCL=OFF
  "-DMLX_C_COMPILER_LAUNCHER=$compiler_launcher_setting"
  "-DFETCHCONTENT_SOURCE_DIR_MLX=$mlx_src"
)
if [ -n "$cmake_generator" ]; then
  no_jaccl_cmake_args=(-G "$cmake_generator" "${no_jaccl_cmake_args[@]}")
fi

hash_stdin() {
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 | awk '{print $1}'
  else
    sha256sum | awk '{print $1}'
  fi
}

cmake_key_file="$build_dir/.mlx-c-jaccl-check-cmake.key"
cmake_key=$(
  {
    cmake --version | sed -n '1p'
    printf '%s\n' "${cmake_args[@]}"
    if command -v shasum >/dev/null 2>&1; then
      shasum -a 256 CMakeLists.txt mlx-c.pc.in examples/CMakeLists.txt
    else
      sha256sum CMakeLists.txt mlx-c.pc.in examples/CMakeLists.txt
    fi
  } | hash_stdin
)
no_jaccl_cmake_key_file="$no_jaccl_build_dir/.mlx-c-jaccl-check-cmake.key"
no_jaccl_cmake_key=$(
  {
    cmake --version | sed -n '1p'
    printf '%s\n' "${no_jaccl_cmake_args[@]}"
    if command -v shasum >/dev/null 2>&1; then
      shasum -a 256 CMakeLists.txt mlx-c.pc.in examples/CMakeLists.txt
    else
      sha256sum CMakeLists.txt mlx-c.pc.in examples/CMakeLists.txt
    fi
  } | hash_stdin
)

case "$(uname -s)" in
Darwin)
  lib_ext=dylib
  exe_suffix=
  ;;
MINGW* | MSYS* | CYGWIN*)
  lib_ext=dll
  exe_suffix=.exe
  ;;
*)
  lib_ext=so
  exe_suffix=
  ;;
esac
consumer_exe="consumer$exe_suffix"
example_jaccl_exe="example-jaccl$exe_suffix"
no_jaccl_consumer_exe="$consumer_exe"
jaccl_required_consumer_exe="$consumer_exe"
no_jaccl_required_stamp="$no_jaccl_required_work_dir/expected-configure-failure"
example_exes=(
  "example$exe_suffix"
  "example-closure$exe_suffix"
  "example-export$exe_suffix"
  "example-float64$exe_suffix"
  "example-gguf$exe_suffix"
  "example-grad$exe_suffix"
  "example-graph$exe_suffix"
  "example-jaccl$exe_suffix"
  "example-metal-kernel$exe_suffix"
  "example-safe-tensors$exe_suffix"
)

repo_paths=(
  CMakeLists.txt
  mlx-c.pc.in
  codegen
  examples
  mlx/c
  internal/mlxcgen
  tools/mlx-c-gen
  tools/mlx-c-gen-cached
  tools/mlx-c-install-smoke
  tools/mlx-c-jaccl-check-cached
  tools/mlx-c-symbol-check
  tools/mlx-c-tool-cached
  go.mod
  go.sum
)

repo_gate_inputs() {
  git ls-files -s -- "${repo_paths[@]}"
  git diff --no-ext-diff --binary -- "${repo_paths[@]}"
  git diff --cached --no-ext-diff --binary -- "${repo_paths[@]}"
  git ls-files --others --exclude-standard -- "${repo_paths[@]}" |
    while IFS= read -r file; do
      if [ -f "$file" ]; then
        printf 'untracked  %s  %s\n' "$(git hash-object "$file")" "$file"
      else
        printf 'untracked-missing  %s\n' "$file"
      fi
    done
}

required_files=(
  "$build_dir/libmlxc.$lib_ext"
  "$build_dir/libjacclc.$lib_ext"
  "$no_jaccl_build_dir/libmlxc.$lib_ext"
  "$work_dir/consumer-build/$consumer_exe"
  "$no_jaccl_work_dir/consumer-build/$no_jaccl_consumer_exe"
  "$jaccl_required_work_dir/consumer-build/$jaccl_required_consumer_exe"
  "$no_jaccl_work_dir/install/lib/libjaccl.$lib_ext"
  "$no_jaccl_required_work_dir/install/lib/libjaccl.$lib_ext"
  "$no_jaccl_required_stamp"
  "$report"
  "$lock_obj"
)
forbidden_files=(
  "$no_jaccl_build_dir/libjacclc.$lib_ext"
  "$no_jaccl_work_dir/install/include/mlx/c/jaccl.h"
  "$no_jaccl_required_work_dir/consumer-build/$consumer_exe"
)
for exe in "${example_exes[@]}"; do
  required_files+=("$build_dir/examples/$exe")
done

artifact_gate_inputs() {
  for file in "${required_files[@]}"; do
    if [ -f "$file" ]; then
      if stat_data=$(stat -f '%z %m' "$file" 2>/dev/null); then
        printf 'artifact  %s  %s\n' "$stat_data" "$file"
      else
        stat_data=$(stat -c '%s %Y' "$file")
        printf 'artifact  %s  %s\n' "$stat_data" "$file"
      fi
    else
      printf 'missing  %s\n' "$file"
    fi
  done
  for file in "${forbidden_files[@]}"; do
    if [ -e "$file" ]; then
      printf 'unexpected  %s\n' "$file"
    else
      printf 'absent  %s\n' "$file"
    fi
  done
}

compute_gate_key() {
  {
    printf 'mlx-c-jaccl-check-v6\n'
    printf 'repo=%s\n' "$repo"
    printf 'cmake_key=%s\n' "$cmake_key"
    printf 'no_jaccl_cmake_key=%s\n' "$no_jaccl_cmake_key"
    printf 'cmake_generator=%s\n' "$cmake_generator"
    printf 'build_dir=%s\n' "$build_dir"
    printf 'no_jaccl_build_dir=%s\n' "$no_jaccl_build_dir"
    printf 'work_dir=%s\n' "$work_dir"
    printf 'no_jaccl_work_dir=%s\n' "$no_jaccl_work_dir"
    printf 'jaccl_required_work_dir=%s\n' "$jaccl_required_work_dir"
    printf 'no_jaccl_required_work_dir=%s\n' "$no_jaccl_required_work_dir"
    printf 'mlx_src=%s\n' "$mlx_src"
    printf 'cc_cmd=%s\n' "$cc_cmd"
    printf 'compiler_launcher_setting=%s\n' "$compiler_launcher_setting"
    printf 'compiler_launcher=%s\n' "$compiler_launcher"
    go env GOVERSION GOOS GOARCH CGO_ENABLED GOFLAGS 2>/dev/null || true
    clang++ --version 2>/dev/null | sed -n '1p' || true
    clang-format --version 2>/dev/null || true
    "$cc_cmd" --version 2>/dev/null | sed -n '1p' || true
    if [ -n "$compiler_launcher" ]; then
      "$compiler_launcher" --version 2>/dev/null | sed -n '1p' || true
    fi
    cmake --version 2>/dev/null | sed -n '1p' || true
    if command -v ninja >/dev/null 2>&1; then
      printf 'ninja=%s\n' "$(ninja --version)"
    fi
    git -C "$mlx_src" rev-parse HEAD 2>/dev/null || true
    git -C "$mlx_src" status --porcelain=v1 --untracked-files=no 2>/dev/null || true
    repo_gate_inputs
    artifact_gate_inputs
  } | hash_stdin
}

gate_key_file="$root/.mlx-c-jaccl-check.key"
gate_stamp="$root/.mlx-c-jaccl-check.success"
result_cache=true
case "${MLX_C_CHECK_RESULT_CACHE:-1}" in
0 | false | FALSE | no | NO)
  result_cache=false
  ;;
esac
force_check=false
case "${MLX_C_CHECK_FORCE:-0}" in
1 | true | TRUE | yes | YES)
  force_check=true
  ;;
esac

gate_key=""
if [ "$result_cache" = true ] && [ "$force_check" = false ]; then
  gate_key=$(compute_gate_key)
fi

cache_ready=true
for file in "${required_files[@]}"; do
  if [ ! -e "$file" ]; then
    cache_ready=false
    break
  fi
done
if [ "$cache_ready" = true ]; then
  for file in "${forbidden_files[@]}"; do
    if [ -e "$file" ]; then
      cache_ready=false
      break
    fi
  done
fi

if [ "$result_cache" = true ] &&
   [ "$force_check" = false ] &&
   [ "$cache_ready" = true ] &&
   [ -f "$gate_key_file" ] &&
   [ -f "$gate_stamp" ] &&
   [ "$(cat "$gate_key_file")" = "$gate_key" ]; then
  printf 'jaccl check: cached success %s\n' "$(cat "$gate_stamp")"
  printf 'report: %s\n' "$report"
  exit 0
fi

if [ ! -f "$build_dir/CMakeCache.txt" ] ||
   [ ! -f "$cmake_key_file" ] ||
   [ "$(cat "$cmake_key_file")" != "$cmake_key" ] ||
   [ ! -d "$mlx_src" ]; then
  cmake "${cmake_args[@]}"
  mkdir -p "$build_dir"
  printf '%s\n' "$cmake_key" >"$cmake_key_file"
else
  printf 'cmake: cached configure %s\n' "$build_dir"
fi
if [ ! -f "$no_jaccl_build_dir/CMakeCache.txt" ] ||
   [ ! -f "$no_jaccl_cmake_key_file" ] ||
   [ "$(cat "$no_jaccl_cmake_key_file")" != "$no_jaccl_cmake_key" ] ||
   [ ! -d "$mlx_src" ]; then
  cmake "${no_jaccl_cmake_args[@]}"
  mkdir -p "$no_jaccl_build_dir"
  printf '%s\n' "$no_jaccl_cmake_key" >"$no_jaccl_cmake_key_file"
else
  printf 'cmake: cached configure %s\n' "$no_jaccl_build_dir"
fi

tools/mlx-c-gen-cached parse \
  --manifest=codegen/manifest.yaml \
  --custom-dir=codegen/custom \
  --types=codegen/types.yaml \
  --mlx-src="$mlx_src" \
  --ast-cache="$ast_cache" \
  --out="$parse_dir/ir1.json" \
  --report="$parse_dir/report1.json"
tools/mlx-c-gen-cached parse \
  --manifest=codegen/manifest.yaml \
  --custom-dir=codegen/custom \
  --types=codegen/types.yaml \
  --mlx-src="$mlx_src" \
  --ast-cache="$ast_cache" \
  --out="$parse_dir/ir2.json" \
  --report="$parse_dir/report2.json"
cmp "$parse_dir/ir1.json" "$parse_dir/ir2.json"
cmp "$parse_dir/report1.json" "$parse_dir/report2.json"

cmake --build "$build_dir" -j
"$build_dir/examples/$example_jaccl_exe"
cmake --build "$no_jaccl_build_dir" -j

tools/mlx-c-gen-cached check \
  --manifest=codegen/manifest.yaml \
  --custom-dir=codegen/custom \
  --types=codegen/types.yaml \
  --mlx-src="$mlx_src" \
  --ast-cache="$ast_cache" \
  --symbol "mlxc=$build_dir/libmlxc.$lib_ext" \
  --symbol "jacclc=$build_dir/libjacclc.$lib_ext" \
  --report="$report"

lock_compile=("$cc_cmd" -std=c11 -I. -c codegen/lock.c -o "$lock_obj")
if [ -n "$compiler_launcher" ]; then
  lock_compile=("$compiler_launcher" "${lock_compile[@]}")
fi
"${lock_compile[@]}"

smoke_args=(
  --build-dir "$build_dir"
  --work-dir "$work_dir"
)
if [ -n "$cmake_generator" ]; then
  smoke_args+=(--generator "$cmake_generator")
fi

rm -rf "$work_dir/install"
tools/mlx-c-tool-cached mlx-c-install-smoke "${smoke_args[@]}"

jaccl_required_smoke_args=(
  --build-dir "$build_dir"
  --consumer codegen/smoke/cmake-jaccl-consumer
  --work-dir "$jaccl_required_work_dir"
)
if [ -n "$cmake_generator" ]; then
  jaccl_required_smoke_args+=(--generator "$cmake_generator")
fi

rm -rf "$jaccl_required_work_dir/install"
tools/mlx-c-tool-cached mlx-c-install-smoke "${jaccl_required_smoke_args[@]}"

no_jaccl_smoke_args=(
  --build-dir "$no_jaccl_build_dir"
  --work-dir "$no_jaccl_work_dir"
)
if [ -n "$cmake_generator" ]; then
  no_jaccl_smoke_args+=(--generator "$cmake_generator")
fi

rm -rf "$no_jaccl_work_dir/install"
tools/mlx-c-tool-cached mlx-c-install-smoke "${no_jaccl_smoke_args[@]}"

no_jaccl_required_smoke_args=(
  --build-dir "$no_jaccl_build_dir"
  --consumer codegen/smoke/cmake-jaccl-consumer
  --work-dir "$no_jaccl_required_work_dir"
  --skip-run
  --expect-configure-failure
  --expect-configure-error "MLXC package was built without JACCL"
)
if [ -n "$cmake_generator" ]; then
  no_jaccl_required_smoke_args+=(--generator "$cmake_generator")
fi

rm -rf "$no_jaccl_required_work_dir/install" "$no_jaccl_required_stamp"
tools/mlx-c-tool-cached mlx-c-install-smoke "${no_jaccl_required_smoke_args[@]}"
mkdir -p "$(dirname "$no_jaccl_required_stamp")"
printf 'expected configure failure\n' >"$no_jaccl_required_stamp"
for file in "${forbidden_files[@]}"; do
  if [ -e "$file" ]; then
    printf 'JACCL-disabled check produced unexpected artifact: %s\n' "$file" >&2
    exit 1
  fi
done

if [ "$result_cache" = true ]; then
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  gate_key=$(compute_gate_key)
  printf '%s\n' "$gate_key" >"$gate_key_file"
  printf '%s\n' "$now" >"$gate_stamp"
fi

printf 'report: %s\n' "$report"
