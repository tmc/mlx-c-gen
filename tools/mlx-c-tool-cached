#!/usr/bin/env bash
set -euo pipefail

repo=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
cd "$repo"

usage() {
  echo "usage: tools/mlx-c-tool-cached <tool> [args...]" >&2
  exit 2
}

if [ "$#" -lt 1 ]; then
  usage
fi

tool=$1
shift

if [[ ! "$tool" =~ ^mlx-c-[A-Za-z0-9_-]+$ ]]; then
  usage
fi

tool_dir="tools/$tool"
if [ ! -d "$tool_dir" ]; then
  echo "mlx-c-tool-cached: unknown tool $tool" >&2
  exit 2
fi

if [ -n "${MLX_C_TOOL_CACHE:-}" ]; then
  cache_dir=$MLX_C_TOOL_CACHE
elif [ -n "${MLX_C_GEN_CACHE:-}" ]; then
  cache_dir=$MLX_C_GEN_CACHE
elif [ "$(uname -s)" = Darwin ]; then
  cache_dir="${HOME}/Library/Caches/mlx-c/mlxcgen/bin"
else
  cache_dir="${XDG_CACHE_HOME:-${HOME}/.cache}/mlx-c/mlxcgen/bin"
fi

mkdir -p "$cache_dir"

bin="$cache_dir/$tool"
env_file="$cache_dir/$tool.env"
go_env=$(go env GOVERSION GOOS GOARCH CGO_ENABLED GOFLAGS 2>/dev/null || true)

rebuild=false
if [ ! -x "$bin" ]; then
  rebuild=true
elif [ ! -f "$env_file" ] || [ "$(cat "$env_file")" != "$go_env" ]; then
  rebuild=true
elif [ -n "$(find go.mod go.sum internal/mlxcgen "$tool_dir" -type f \( -name '*.go' -o -name go.mod -o -name go.sum \) -newer "$bin" -print -quit)" ]; then
  rebuild=true
fi

if [ "$rebuild" = true ]; then
  tmp=$(mktemp "$cache_dir/$tool.tmp.XXXXXX")
  rm -f "$tmp"
  go build -o "$tmp" "./$tool_dir"
  chmod 0755 "$tmp"
  mv "$tmp" "$bin"
  printf '%s\n' "$go_env" >"$env_file"
fi

exec "$bin" "$@"
